# Ottieni queste credenziali da https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# URI di redirect registrato nell'app Spotify (deve corrispondere esattamente)
REDIRECT_URI=http://localhost:8000/callback

# Chiave segreta per firmare i cookie di sessione (genera con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_this_to_a_random_secret_key
